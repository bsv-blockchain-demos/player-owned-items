# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/monster-battle?retryWrites=true&w=majority

# JWT Secret (use a strong random string in production)
JWT_SECRET=your-secret-key-change-this-in-production

# Server Wallet Configuration (for server-side item minting)
# Generate a new private key for production - this wallet is the single source of truth for all game items
SERVER_PRIVATE_KEY=your-private-key-hex-here
WALLET_STORAGE_URL=https://store-us-1.bsvb.tech
BSV_NETWORK=test

# Minimum wallet balance required for the app to be considered "ready"
MIN_BALANCE=10000